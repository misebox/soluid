{
  "name": "soluid",
  "version": "0.1.4",
  "type": "module",
  "description": "SolidJS Opinionated UI - copy-paste component toolkit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/misebox/soluid.git"
  },
  "homepage": "https://github.com/misebox/soluid",
  "keywords": [
    "solidjs",
    "ui",
    "components",
    "cli"
  ],
  "bin": {
    "soluid": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run precatalog && vite --open /soluid/",
    "generate:css": "bunx tsx scripts/generate-css-imports.ts",
    "generate:api": "bunx tsx scripts/generate-api-data.ts",
    "precatalog": "bun run generate:css && bun run generate:api",
    "build:catalog": "bun run precatalog && vite build --config vite.config.catalog.ts",
    "build:cli": "tsc -p cli/tsconfig.json",
    "prepare": "bun run build:cli",
    "typecheck": "tsc --noEmit",
    "fmt": "dprint fmt",
    "fmt:check": "dprint check",
    "lint": "oxlint src/ cli/",
    "lint:fix": "oxlint --fix src/ cli/",
    "push:check": "sh bin/check-build-freshness.sh"
  },
  "devDependencies": {
    "@floating-ui/dom": "^1.7.5",
    "@solid-primitives/active-element": "^2.1.5",
    "@solid-primitives/event-listener": "^2.4.5",
    "@solid-primitives/scheduled": "^1.5.3",
    "@solidjs/router": "^0.15.4",
    "@types/node": "^20.19.34",
    "dprint": "^0.52.0",
    "oxlint": "^1.50.0",
    "solid-js": "^1.9.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0"
  },
  "dependencies": {
    "tar": "^7.5.9"
  }
}
