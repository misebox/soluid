{
  "name": "solidout",
  "version": "0.1.0",
  "componentsVersion": "0.1.0",
  "type": "module",
  "description": "SolidJS Opinionated UI - copy-paste component toolkit",
  "license": "MIT",
  "bin": {
    "solidout": "./dist/index.js"
  },
  "files": [
    "dist",
    "src/core/solidout.css"
  ],
  "scripts": {
    "dev": "vite",
    "build:cli": "tsc -p cli/tsconfig.json",
    "prepare": "npm run build:cli",
    "typecheck": "tsc --noEmit",
    "fmt": "dprint fmt",
    "fmt:check": "dprint check",
    "lint": "oxlint src/ cli/",
    "lint:fix": "oxlint --fix src/ cli/"
  },
  "devDependencies": {
    "@types/node": "^20.19.34",
    "dprint": "^0.52.0",
    "oxlint": "^1.50.0",
    "solid-js": "^1.9.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0"
  },
  "dependencies": {
    "tar": "^7.5.9"
  }
}
